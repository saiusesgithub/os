Q1: Simulate the following CPU Scheduling Algorithm using C program: FCFS.

#include<stdio.h>

int main() {
    int n, bt[20], wt[20], tat[20];
    int i;
    float avwt = 0, avtat = 0;

    scanf("%d", &n);

    for(i = 0; i < n; i++) {
        scanf("%d", &bt[i]);
    }

    wt[0] = 0;

    for(i = 1; i < n; i++) {
        wt[i] = wt[i-1] + bt[i-1];
    }

    for(i = 0; i < n; i++) {
        tat[i] = wt[i] + bt[i];
    }

    for(i = 0; i < n; i++) {
        avwt += wt[i];
        avtat += tat[i];
    }

    avwt /= n;
    avtat /= n;

    printf("%.2f %.2f", avwt, avtat);

    return 0;
}
